<h1 style="text-align:center;">Crypto Prices</h1>

<div style="max-width:600px; margin: 0 auto;">

  <%= form_with url: root_path, method: :get, local: true, style: "display:flex; gap:10px; margin-bottom:20px;" do %>
    <%= text_field_tag :symbol, nil, placeholder: "Search coin (e.g. bitcoin)",
        style: "flex:1; padding:8px; border:1px solid #ccc; border-radius:6px;" %>
    <%= submit_tag "Search",
        style: "padding:8px 16px; border:none; background:#333; color:#fff; border-radius:6px;" %>
  <% end %>

  <table style="width:100%; border-collapse: collapse;">
    <thead>
      <tr style="text-align:left; border-bottom:1px solid #ddd;">
        <th style="padding:10px;">Symbol</th>
        <th style="padding:10px;">Price (USD)</th>
      </tr>
    </thead>

    <tbody>
      <% @prices.each do |p| %>
        <tr style="border-bottom:1px solid #f0f0f0;">
          <td style="padding:10px;">
            <%= link_to p.symbol, price_path(p.symbol),
                style: "text-decoration:none; color:#007bff;" %>
          </td>
          <td style="padding:10px;">
            <%= p.price || 0 %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

</div>
